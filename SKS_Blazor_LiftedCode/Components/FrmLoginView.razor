@page "/frmLogin"
@using Gap.Blazor.Components
@rendermode RenderMode.InteractiveServer
@using SKS.Components
@inherits ComponentBase
@namespace SKS.Components.Pages
<WMFormComponent model="@this.model">
    <WMLabelComponent model="@this.model._lblLabels_1"></WMLabelComponent>
    <WMLabelComponent model="@this.model._lblLabels_0"></WMLabelComponent>
    <WMButtonComponent model="@this.model.cmdOK"></WMButtonComponent>
    <WMTextBoxComponent model="@this.model.txtPassword"></WMTextBoxComponent>
    <WMButtonComponent model="@this.model.cmdCancel"></WMButtonComponent>
    <WMTextBoxComponent model="@this.model.txtUserName"></WMTextBoxComponent>
    <WMToolTipComponent model="@this.model.ToolTipMain"></WMToolTipComponent>
</WMFormComponent>
@code {
    [Parameter]
    public frmLogin model { get; set; }
    protected override void OnInitialized()
    {
        base.OnInitialized();
        model = model == null ? new frmLogin() : model;
        model.View = this.GetType();
    }
}
